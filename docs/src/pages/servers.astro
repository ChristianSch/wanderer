---
import PageNav from "../components/page_nav.astro";
import PageFooter from "../components/page_footer.astro";
import ServerList from "../components/server_list.svelte";
import servers from "../../public/server/servers.json";

import "@fontsource/ibm-plex-sans/400.css";
import "@fontsource/ibm-plex-sans/600.css";
import "@fontsource/ibm-plex-sans/700.css";
import "@fontsource/ibm-plex-mono/400.css";

---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Servers — wanderer</title>
    <meta
      name="description"
      content="Browse publicly listed wanderer servers. Find a community to join or host your own instance."
    />
    <link rel="icon" href="/favicon.svg" />
  </head>

  <body>
    <!-- ─── NAV ──────────────────────────────────────────────────────────── -->
    <PageNav />

    <!-- ─── PAGE HEADER ───────────────────────────────────────────────────── -->
    <header class="page-header">
      <div class="page-header-inner">
        <div class="page-header-text">
          <h1 class="page-title">Find your wanderer server.</h1>
          <p class="page-subtitle">
            Each server is an independent wanderer installation with its own community.
            Join one that fits — or <a href="/run/installation/quick" class="inline-link">run your own</a>.
          </p>
        </div>
        <div class="page-header-meta">
          <span class="server-count">
            <strong>{servers.length}</strong> servers listed
          </span>
          <a
            href="https://github.com/open-wanderer/wanderer/discussions/361"
            class="add-server-link"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
            Add your server
          </a>
        </div>
      </div>
    </header>

    <!-- ─── SERVER LIST ───────────────────────────────────────────────────── -->
    <main class="main" id="main-content">
      <ServerList {servers} client:load />
    </main>

    <PageFooter />
  </body>
</html>

<style>
  /* ── Reset & Base ───────────────────────────────────────────────────────── */
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    font-size: 16px;
    -webkit-font-smoothing: antialiased;
    scroll-behavior: smooth;
  }

  body {
    font-family:
      "IBM Plex Sans",
      -apple-system,
      BlinkMacSystemFont,
      sans-serif;
    background: #12141c;
    color: #ffffff;
    line-height: 1.6;
    min-height: 100vh;
    overflow-x: clip;
  }

  img,
  video {
    display: block;
    max-width: 100%;
  }

  a {
    color: inherit;
  }

  /* ── CSS Custom Properties ─────────────────────────────────────────────── */
  :root {
    --deep-void: #12141c;
    --polar-night: #242734;
    --surface-dark: #1e2028;
    --carbon: #262831;
    --dusk-divide: #374151;
    --summit-fog: #94a3b8;
    --white: #ffffff;
    --signal-red: #ef4444;
    --abyss: #070a24;

    --container: min(1160px, 100% - 3rem);

  }

  /* ── PAGE HEADER ───────────────────────────────────────────────────────── */
  .page-header {
    background: var(--polar-night);
    border-bottom: 1px solid var(--dusk-divide);
    padding: clamp(2.5rem, 5vw, 4rem) clamp(1rem, 4vw, 2.5rem);
  }

  .page-header-inner {
    width: var(--container);
    margin-inline: auto;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .page-title {
    font-size: clamp(1.875rem, 4vw, 3rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.03em;
    text-wrap: balance;
    margin-bottom: 0.875rem;
  }

  .page-subtitle {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--summit-fog);
    max-width: 54ch;
  }

  .inline-link {
    color: var(--white);
    text-decoration: underline;
    text-decoration-color: rgba(255, 255, 255, 0.35);
    text-underline-offset: 3px;
    transition: text-decoration-color 0.15s ease;
  }
  .inline-link:hover {
    text-decoration-color: var(--white);
  }

  .page-header-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .server-count {
    font-size: 0.875rem;
    color: var(--summit-fog);
  }
  .server-count strong {
    color: var(--white);
    font-weight: 600;
  }

  .add-server-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--white);
    text-decoration: none;
    padding: 0.5rem 0.875rem;
    border: 1px solid var(--dusk-divide);
    border-radius: 6px;
    background: rgba(55, 65, 81, 0.3);
    transition: border-color 0.15s ease, background 0.15s ease;
    white-space: nowrap;
  }
  .add-server-link:hover {
    border-color: rgba(255, 255, 255, 0.3);
    background: rgba(55, 65, 81, 0.6);
  }

  @media (max-width: 600px) {
    .page-header-inner {
      flex-direction: column;
      align-items: flex-start;
    }
    .page-header-meta {
      align-items: flex-start;
      flex-direction: row;
      flex-wrap: wrap;
    }
  }

  /* ── MAIN ──────────────────────────────────────────────────────────────── */
  .main {
    width: var(--container);
    margin-inline: auto;
    padding: clamp(2rem, 5vw, 4rem) 0 clamp(3rem, 7vw, 6rem);
  }
</style>
