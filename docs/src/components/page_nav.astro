---
import LogoTextLight from "../assets/logo_text_light.svg";

let starCount = "★";
try {
  const r = await fetch("https://api.github.com/repos/open-wanderer/wanderer", {
    headers: { "User-Agent": "wanderer-docs/1.0" },
    signal: AbortSignal.timeout(3000),
  });
  if (r.ok) {
    const d: { stargazers_count?: number } = await r.json();
    const n = d.stargazers_count ?? 0;
    starCount = n >= 1000 ? `${(n / 1000).toFixed(1)}k` : String(n);
  }
} catch { /* show fallback */ }
---

<nav class="nav" aria-label="Main navigation">
  <a href="/" class="nav-logo" aria-label="wanderer home">
    <LogoTextLight height="36" width="119.25" />
  </a>

  <div class="nav-links" aria-label="Documentation links">
    <a href="/welcome" class="nav-link">Docs</a>
    <a href="/run/installation/quick" class="nav-link">Install</a>
    <a href="/api-reference" class="nav-link">API</a>
    <a href="/changelog" class="nav-link">Changelog</a>
  </div>

  <div class="nav-actions">
    <a
      href="https://github.com/open-wanderer/wanderer"
      class="nav-stars"
      target="_blank"
      rel="noopener noreferrer"
      aria-label={`${starCount} GitHub stars`}
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"
        ><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
        ></path></svg
      >
      <span>{starCount}</span>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path>
      </svg>
    </a>
    <a
      href="https://demo.wanderer.to"
      class="nav-demo"
      target="_blank"
      rel="noopener noreferrer"
    >
      Try Demo
    </a>
  </div>
</nav>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding: 0 clamp(1rem, 4vw, 2.5rem);
    height: 60px;
    background: rgba(18, 20, 28, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(55, 65, 81, 0.6);
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    text-decoration: none;
    flex-shrink: 0;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    flex: 1;
  }

  .nav-link {
    padding: 0.375rem 0.75rem;
    font-size: 0.875rem;
    color: var(--summit-fog);
    text-decoration: none;
    border-radius: 6px;
    transition: color 0.15s ease, background 0.15s ease;
  }
  .nav-link:hover {
    color: var(--white);
    background: rgba(255, 255, 255, 0.06);
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .nav-stars {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.75rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--summit-fog);
    background: rgba(55, 65, 81, 0.4);
    border: 1px solid var(--dusk-divide);
    border-radius: 6px;
    text-decoration: none;
    transition: color 0.15s ease, background 0.15s ease;
  }
  .nav-stars:hover {
    color: var(--white);
    background: rgba(55, 65, 81, 0.7);
  }

  .nav-demo {
    padding: 0.375rem 1rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--deep-void);
    background: var(--white);
    border-radius: 6px;
    text-decoration: none;
    transition: background 0.15s ease;
  }
  .nav-demo:hover {
    background: #e5e7eb;
  }

  @media (max-width: 640px) {
    .nav-links { display: none; }
  }
  @media (max-width: 400px) {
    .nav-stars { display: none; }
  }
</style>
